{
  "$schema": "https://railway.app/railway.schema.json",
  "deploy": {
    "startCommand": "python manage.py migrate && gunicorn edu2job_backend.wsgi:application --bind 0.0.0.0:8080",
    "healthcheckPath": "/test/",
    "healthcheckTimeout": 60,
    "ports": [
      {
        "port": 8080,
        "protocol": "HTTP"
      }
    ]
  }
}
